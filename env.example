# Environment variables for Contract Intelligence API
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git (it's in .gitignore)

# Pinecone (from Day 7)
PINECONE_API_KEY=your-pinecone-api-key-here

# Hugging Face (get from https://huggingface.co/settings/tokens)
HF_TOKEN=your-hf-token-here

# Your model URL on HF Hub (set after uploading model)
# Format: https://api-inference.huggingface.co/models/your-username/your-model-name
HF_MODEL_URL=https://api-inference.huggingface.co/models/your-username/contract-intelligence
